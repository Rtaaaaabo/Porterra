generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PostVisibility {
  CUSTOM
  FRIENDS
  PUBLIC
}

model User {
  id                     String                 @id @default(cuid())
  name                   String
  email                  String                 @unique
  passwordHash           String
  createdAt              DateTime               @default(now())
  posts                  Post[]
  likes                  Like[]
  sessions               Session[]
  postVisibilityAccesses PostVisibilityAccess[]
  friendships            Friendship[]           @relation("UserFriendships")
  friendedBy             Friendship[]           @relation("UserFriendedBy")

  @@map("users")
}

model Spot {
  id         String   @id @default(cuid())
  name       String
  prefecture String
  country    String
  lat        Float?
  lng        Float?
  createdAt  DateTime @default(now())
  posts      Post[]

  @@map("spots")
}

model Post {
  id                 String                 @id @default(cuid())
  title              String
  body               String
  userId             String
  spotId             String
  visibility         PostVisibility         @default(PUBLIC)
  createdAt          DateTime               @default(now())
  user               User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  spot               Spot                   @relation(fields: [spotId], references: [id], onDelete: Cascade)
  images             PostImage[]
  likes              Like[]
  visibilityAccesses PostVisibilityAccess[]

  @@index([userId])
  @@index([spotId])
  @@map("posts")
}

model PostVisibilityAccess {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
  @@map("post_visibility_accesses")
}

model Friendship {
  id           String   @id @default(cuid())
  userId       String
  friendUserId String
  createdAt    DateTime @default(now())
  user         User     @relation("UserFriendships", fields: [userId], references: [id], onDelete: Cascade)
  friendUser   User     @relation("UserFriendedBy", fields: [friendUserId], references: [id], onDelete: Cascade)

  @@unique([userId, friendUserId])
  @@index([userId])
  @@index([friendUserId])
  @@map("friendships")
}

model PostImage {
  id        String   @id @default(cuid())
  postId    String
  imageUrl  String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("post_images")
}

model Like {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
  @@map("likes")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}
